{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "src/routes/**/+{page,server,page.server,error,layout,layout.server}{,@*}.{js,ts,svelte}",
    "src/lib/server/db/index.ts",
    "src/lib/server/auth.ts",
    "src/lib/server/jobs/cleanup-scheduler.ts"
  ],
  "project": ["src/**/*.{js,ts,svelte}"],
  "ignoreExportsUsedInFile": true,
  "ignoreFiles": ["src/lib/server/db/test-utils.ts"],
  "ignoreIssues": {
    "src/lib/server/db/db.ts": ["exports"],
    "src/lib/server/error-handler.ts": ["exports"],
    "src/lib/server/utils/simple-ingest.ts": ["types"]
  },
  "ignoreDependencies": ["tw-animate-css", "@divkix/logwell", "layerchart", "@types/d3-scale"],
  "ignoreBinaries": ["jsr"],
  "ignoreUnresolved": ["\\$env/.+", "\\$\\{packageName\\}"],
  "drizzle": false
}
