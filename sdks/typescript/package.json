{
  "name": "logwell",
  "version": "1.1.0",
  "description": "Official TypeScript SDK for Logwell logging platform",
  "keywords": [
    "logging",
    "logs",
    "logwell",
    "observability",
    "typescript"
  ],
  "homepage": "https://github.com/Divkix/Logwell/tree/main/sdks/typescript#readme",
  "bugs": {
    "url": "https://github.com/Divkix/Logwell/issues"
  },
  "license": "MIT",
  "author": "Logwell",
  "repository": {
    "type": "git",
    "url": "https://github.com/Divkix/Logwell",
    "directory": "sdks/typescript"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "check": "vp check",
    "lint": "vp check",
    "lint:fix": "vp check --fix",
    "test": "vp test run",
    "test:unit": "vp test run tests/unit/",
    "test:integration": "vp test run tests/integration/",
    "test:coverage": "vp test run --coverage",
    "test:watch": "vp test",
    "prepublishOnly": "bun run build",
    "size": "size-limit",
    "attw": "attw --pack ."
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@vitest/coverage-v8": "^4.1.6",
    "msw": "^2.14.6",
    "size-limit": "^12.1.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.1.24",
    "vite-plus": "0.2.1",
    "vitest": "npm:@voidzero-dev/vite-plus-test@0.1.24"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@0.1.24",
    "vitest": "npm:@voidzero-dev/vite-plus-test@0.1.24"
  },
  "size-limit": [
    {
      "path": "./dist/index.js",
      "limit": "10 KB"
    }
  ],
  "engines": {
    "node": ">=20.0.0"
  }
}
